# Copy this file to .env and fill in your values
# .env is gitignored — never commit credentials

# Azure AI Foundry project endpoint
# Find at: ai.azure.com → your project → Settings → Project details → Endpoint
AZURE_FOUNDRY_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>

# Azure Function invocation URL including the function key
# Get key with: az functionapp keys list --name func-roadmap-sync --resource-group rg-roadmap-sync --query masterKey -o tsv
AZURE_FUNCTION_URL=https://func-roadmap-sync.azurewebsites.net/api/fetch_roadmap?code=<key>

# Azure AI Foundry project API key — used by configure-logic-app.sh to authenticate Logic App HTTP calls
# Find at: ai.azure.com → your project → Settings → API keys
AZURE_FOUNDRY_API_KEY=<your-foundry-api-key>

# Foundry Agent ID — printed by create-foundry-agent.py as "Agent ID for Logic Apps: asst_..."
# Used by configure-logic-app.sh to wire up the Logic App workflow
AZURE_AGENT_ID=asst_<your-agent-id>

# Azure DevOps PAT — used by the ado_operations Function App to authenticate to ADO
# Required scope: Work Items (Read & Write)
# Create at: https://dev.azure.com/hobbitfeetado/_usersSettings/tokens
# This is also set as a Function App setting by deploy-azure-resources.sh
ADO_PAT=<your-ado-pat>
